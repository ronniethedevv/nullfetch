# ── chain / RPC ─────────────────────────────────────────────────────
# 12-word BIP-39 mnemonic. The first derived account is the deployer +
# (by default) the marketplace owner.
MNEMONIC=

# Infura project ID for Sepolia RPC. Optional — falls back to the public
# rpc.sepolia.org endpoint if unset, but a private RPC is strongly
# recommended for production use.
INFURA_API_KEY=

# Etherscan v2 API key. Optional — when set, `npm run deploy:sepolia`
# verifies the contract source on Sepolia Etherscan after deploy.
ETHERSCAN_API_KEY=

# ── contract address ───────────────────────────────────────────────
# Address of the deployed Marketplace on Sepolia. Set after running
# `npm run deploy:sepolia` (also written to deployments.json, so this
# is only needed if you want to point at a contract you didn't deploy
# in this checkout).
MARKETPLACE_ADDRESS=

# ── provider: list a service ───────────────────────────────────────
# Read by `npm run list-service:sepolia`. The provider signs the listing
# tx and pays `listingFee` (default 0.0003 ETH).
SERVICE_NAME=
SERVICE_DESCRIPTION=
SERVICE_ENDPOINT=
# One of: Other, AI, Finance, Data, Weather, Utility, Storage, Communications
SERVICE_CATEGORY=

# ── developer: register / verify ───────────────────────────────────
# Read by `npm run register:sepolia` and `npm run verify-key:sepolia`.
# The developer signs the registration tx and pays `registrationFee`
# (default 0.0003 ETH).
SERVICE_ID=

# Optional override for verify-key.ts. When unset, verify-key reads the
# plaintext from `.key-service-<SERVICE_ID>` (written by register-key.ts).
CANDIDATE_KEY=

# ── API server (api/) ──────────────────────────────────────────────
# Port the demo API listens on (defaults to 3000 if unset).
PORT=3000
