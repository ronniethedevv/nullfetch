{
  "name": "nullfetch",
  "version": "2.0.0",
  "description": "NullFetch — confidential API marketplace on Zama fhEVM. Encrypted per-developer keys; no plaintext at the provider or the marketplace.",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "list-service:sepolia": "hardhat run scripts/list-service.ts --network sepolia",
    "register:sepolia": "hardhat run scripts/register-key.ts --network sepolia",
    "verify-key:sepolia": "hardhat run scripts/verify-key.ts --network sepolia",
    "api:dev": "cd api && npm run dev",
    "web:dev": "cd web && npm run dev"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@fhevm/mock-utils": "0.4.2",
    "@fhevm/solidity": "^0.11.1",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "@types/node": "^20.11.0",
    "@zama-fhe/relayer-sdk": "0.4.1",
    "chai": "^4.2.0",
    "dotenv": "^16.4.5",
    "encrypted-types": "^0.0.4",
    "ethers": "^6.16.0",
    "hardhat": "^2.26.0",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.0",
    "typescript": "^5.4.5"
  }
}
